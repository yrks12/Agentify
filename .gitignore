# Secrets — never commit
.env
.env.local
.env.*.local
**/.env

# Python venv (bundled at install time, not source)
venv/
.venv/
**/venv/
**/.venv/

# Python bytecode and packaging artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
build/
dist/
.eggs/
pip-wheel-metadata/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Recorded recipes — generated by `agentify map`, don't ship
source/recipes/*.json
!source/recipes/.gitkeep

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Playwright cache (lives outside repo, but defensive)
ms-playwright/
